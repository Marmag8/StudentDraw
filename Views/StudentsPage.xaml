<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentDraw.Views.StudentsPage"
             Title="Uczniowie">

    <VerticalStackLayout>

        <Button Text="Dodaj klasę"
                Clicked="AddClass" />

        <CollectionView ItemsSource="{Binding GroupedStudents}"
                        IsGrouped="True">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto, Auto, Auto">
                        <Label Grid.Column="0"
                               Text="{Binding ClassSymbol}"
                               StyleClass="group-header-label"
                               VerticalOptions="Center" />

                        <Button Grid.Column="1"
                                Text="+"
                                StyleClass="add-student-btn"
                                Clicked="AddStudentToClass"
                                CommandParameter="{Binding ClassSymbol}" />
                        <Button Grid.Column="2"
                                Text="Usuń klasę"
                                StyleClass="delete-class-btn"
                                Clicked="DeleteClass"
                                CommandParameter="{Binding ClassSymbol}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <Label Grid.Column="0"
                               Text="{Binding DisplayName}"
                               StyleClass="student-name-label" />
                        <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <CheckBox IsChecked="{Binding IsPresent}"
                                      CheckedChanged="OnIsPresentChanged" />
                                                    <Label Text="obecny" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="2"
                                Text="Usuń"
                                StyleClass="delete-student-btn"
                                Clicked="DeleteStudent"
                                CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>